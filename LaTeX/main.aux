\@writefile{lof}{\contentsline {figure}{\numberline {0.14}{\ignorespaces Elliptical safety zone around a large vessel. Blue arrows represents UAVS, puprle arrow represents a big ship. The safety zone is stretched and shifted along the ship's heading to account for its momentum.}}{39}{}\protected@file@percent }
\newlabel{fig:big_ship_safe_zone}{{0.14}{39}{Elliptical safety zone around a large vessel. Blue arrows represents UAVS, puprle arrow represents a big ship. The safety zone is stretched and shifted along the ship's heading to account for its momentum}{}{}}
\newlabel{fig:big_ship_avoidance_simulation_1}{{0.15a}{40}{Initial approach: The vessel (yellow) approaches at 35\,kts. Drones are initially on a collision course. Drones immediately detect the vessel and begin evasive maneuvers to steer clear of the safety zone}{}{}}
\newlabel{sub@fig:big_ship_avoidance_simulation_1}{{a}{40}{Initial approach: The vessel (yellow) approaches at 35\,kts. Drones are initially on a collision course. Drones immediately detect the vessel and begin evasive maneuvers to steer clear of the safety zone}{}{}}
\newlabel{fig:big_ship_avoidance_simulation_2}{{0.15b}{40}{Continous avoidance: Yellow ship makes sharp U turn going back into drones trajectory. UAVs deviate from the ship's trajectory to minimize time in the danger zone, and tries to achieve a waypoint at a same time}{}{}}
\newlabel{sub@fig:big_ship_avoidance_simulation_2}{{b}{40}{Continous avoidance: Yellow ship makes sharp U turn going back into drones trajectory. UAVs deviate from the ship's trajectory to minimize time in the danger zone, and tries to achieve a waypoint at a same time}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {0.15}{\ignorespaces Simulation of the AIS vessel avoidance system. The drones successfully detect and maneuver around the high-speed commercial vessel to maintain the safety buffer, while still progressing towards their waypoint. The elliptical safety zone is clearly visible as the drones adjust their paths to minimize time spent within it.}}{40}{}\protected@file@percent }
\newlabel{fig:big_ship_avoidance_simulation}{{0.15}{40}{Simulation of the AIS vessel avoidance system. The drones successfully detect and maneuver around the high-speed commercial vessel to maintain the safety buffer, while still progressing towards their waypoint. The elliptical safety zone is clearly visible as the drones adjust their paths to minimize time spent within it}{}{}}
